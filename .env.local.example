# Copy this file to .env.local and fill in your values.
# These are loaded automatically by Next.js — no extra steps needed.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here          # Get at console.anthropic.com

# ── Authentication ────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-generated-secret
NEXTAUTH_URL=http://localhost:3000              # Change to your public URL in production

# ── Optional — disables login screen (local dev / Electron builds only) ───────
# SKIP_AUTH=true

# ── Optional — "The Eyes" research features ───────────────────────────────────
# PERPLEXITY_API_KEY=pplx-your-key-here         # Live web research + Twitter/X listening
# FIRECRAWL_API_KEY=fc-your-key-here            # JS-rendered site scraping (G2, Capterra)

# ── Database (defaults to local SQLite — usually no change needed) ────────────
# DATABASE_URL=file:./dev.db
