# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # Claude Opus 4.6 — core analysis

# ── The Eyes (optional but highly recommended) ────────────────────────────────
PERPLEXITY_API_KEY=your_perplexity_api_key_here # Perplexity Sonar — research + Twitter/X
FIRECRAWL_API_KEY=your_firecrawl_api_key_here   # Firecrawl — JS-rendered sites (G2, Capterra, SPAs)

# ── Database (optional — defaults to local SQLite) ────────────────────────────
# DATABASE_URL=file:./dev.db

# ── Authentication (Sprint 3.1) ───────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
# Set SKIP_AUTH=true to bypass login (local dev / Electron builds)
# SKIP_AUTH=true
