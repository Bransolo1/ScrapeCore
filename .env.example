# ─── Required ─────────────────────────────────────────────────────────────────

# NextAuth session secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# App URL (used for OAuth callbacks and internal API calls)
NEXTAUTH_URL=http://localhost:3000

# AES-256 encryption key for user API keys — generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── AI / Scraping API Keys ──────────────────────────────────────────────────

# Anthropic API key for Claude analysis
ANTHROPIC_API_KEY=

# Firecrawl API key for web crawling (optional)
FIRECRAWL_API_KEY=

# Perplexity API key for competitive intel (optional)
PERPLEXITY_API_KEY=

# ─── OAuth (optional) ────────────────────────────────────────────────────────

# Google OAuth for sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database ─────────────────────────────────────────────────────────────────

# Turso/LibSQL database URL
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ─── Security ─────────────────────────────────────────────────────────────────

# Secret for cron endpoint auth — generate with: openssl rand -base64 32
# REQUIRED in production — without this, cron endpoints will reject all requests
CRON_SECRET=

# Set to "true" to disable auth (local dev / Electron builds only)
# SKIP_AUTH=true
