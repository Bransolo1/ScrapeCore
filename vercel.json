{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && npx prisma migrate deploy && next build",
  "functions": {
    "app/api/analyze/route.ts": {
      "maxDuration": 60
    },
    "app/api/monitoring/run/*/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/monitoring/route.ts": {
      "maxDuration": 60
    },
    "app/api/sources/*/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/monitoring",
      "schedule": "0 6 * * *"
    }
  ]
}
