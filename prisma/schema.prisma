generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  email          String        @unique
  name           String?
  passwordHash   String?
  role           String        @default("analyst")  // analyst | admin
  organisationId String?
  organisation   Organisation? @relation(fields: [organisationId], references: [id])
  analyses       Analysis[]
  auditLogs      AuditLog[]
  apiKeys        UserApiKey[]
  costSettings   UserCostSettings?
}

model UserApiKey {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // anthropic | firecrawl | perplexity
  cipher    String   // AES-256-GCM encrypted key
  iv        String   // initialisation vector (hex)
  tag       String   // GCM auth tag (hex)
  hint      String   // last 4 chars for UI display
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Organisation {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  name      String
  users     User[]
  analyses  Analysis[]
}

model Analysis {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  title        String
  dataType     String
  analysisJson String
  inputText    String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  durationMs   Int?
  project      String?
  tags         String   @default("[]")

  // Human review workflow
  reviewStatus String    @default("pending")  // pending | approved | disputed | archived
  reviewNotes  String?
  reviewedAt   DateTime?
  reviewedBy   String?

  // PII flag — set if PII was detected in input text at analysis time
  piiDetected  Boolean  @default(false)

  // Prompt Systems
  promptVersion  String?  // e.g. "v2.1"
  projectContext String?  // analyst-supplied research question / target population

  // Eval log — grounding score, validity scores, computed at save time
  evalJson     String?  // JSON: { groundingScore, ungroundedCount, avgValidityScore, weakInterventions }

  // Rubric auto-score — 10-dimension evaluation_rubric.md scores, computed at save time
  rubricJson   String?  // JSON: { dimensions: [{name, score, rationale}], total, grade }

  // Eval pass/fail criteria (master doc: explicit success/failure per analysis)
  evalPassed   Boolean?  // true = rubric grade is strong/acceptable; false = needs_revision
  evalNotes    String?   // auto-generated rubric summary for the eval log

  // Multi-tenancy
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])
  organisationId String?
  organisation   Organisation? @relation(fields: [organisationId], references: [id])

  // Shareable read-only link
  shareToken String? @unique

  auditLogs    AuditLog[]
  corrections  AnalysisCorrection[]
}

model CompetitorMonitor {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  name           String                       // e.g. "Track Monzo reviews"
  competitorName String                       // e.g. "Monzo"
  keywords       String   @default("[]")     // JSON string array of extra search terms
  schedule       String   @default("weekly") // daily | weekly | monthly
  active         Boolean  @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime
  lastAnalysisId String?  // most recently created Analysis id
  userId         String?
  runCount       Int      @default(0)
}

model AnalysisCorrection {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  analysisId   String
  analysis     Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  section      String   // barriers | motivators | key_behaviours | interventions
  itemIndex    Int
  status       String   // confirmed | disputed | removed
  note         String?
  correctedBy  String   @default("analyst")

  @@unique([analysisId, section, itemIndex])
}

model RateLimit {
  id        String   @id           // identifier — IP address or userId
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt
}

model UserCostSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Monthly budget limits (USD cents, null = no limit)
  firecrawlBudgetCents   Int?
  perplexityBudgetCents  Int?
  anthropicBudgetCents   Int?

  // Per-operation limits
  maxUrlsPerScrape       Int      @default(15)
  maxPagesPerCrawl       Int      @default(30)

  // Usage tracking (reset monthly)
  firecrawlCallsThisMonth  Int    @default(0)
  perplexityCallsThisMonth Int    @default(0)
  anthropicTokensThisMonth Int    @default(0)
  usageResetAt             DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  event      String   // analysis.created | analysis.viewed | analysis.exported | review.updated | source.fetched | pii.detected
  actor      String   @default("system")
  entityId   String?
  entityType String?
  metadata   String   @default("{}")  // JSON blob

  analysisId String?
  analysis   Analysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)

  userId  String?
  user    User?    @relation(fields: [userId], references: [id])
}
