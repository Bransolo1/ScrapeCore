# ── ScrapeCore Docker environment ──────────────────────────────────────────
# Copy to .env.docker, fill in values, then:
#   docker compose --env-file .env.docker up -d

# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-generated-secret

# ── Optional ────────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-...

# ── Deployment ──────────────────────────────────────────────────────────────
# Public URL of the app — used by NextAuth for OAuth callback URLs
NEXTAUTH_URL=https://your-domain.com

# Host port to expose (default: 3000)
PORT=3000

# Set to true only for local dev — disables login screen
SKIP_AUTH=false
